# ───────────────────────────────────────────
# Polymarket 钱包认证配置
# ⚠️ 警告：永远不要分享或提交你的私钥！
# ───────────────────────────────────────────

# Polygon 钱包私钥（64字符，0x开头）
# 从 Polymarket 账户设置 → API → 导出私钥 获取
POLYMARKET_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# 钱包地址（42字符，0x开头）
POLYMARKET_FUNDER_ADDRESS=0xYOUR_WALLET_ADDRESS_HERE

# Polygon 主网 Chain ID
POLYMARKET_CHAIN_ID=137

# 签名类型：0=MetaMask硬件钱包 1=邮箱注册 2=浏览器代理/Polymarket原生
SIGNATURE_TYPE=2

# ───────────────────────────────────────────
# 策略参数配置
# ───────────────────────────────────────────

# 单次市场总预算（USDC）
MAX_BUDGET=10.0

# 价格触发阈值（当 Yes/No ask 价格低于此值时买入）
# ⚠️ 默认0.50，但数学期望为负，请谨慎调整
PRICE_THRESHOLD=0.50

# 价格检查间隔（秒）
CHECK_INTERVAL=30

# 目标市场 Condition ID（从 list-markets 命令获取）
# 示例：BTC $1M before GTA VI
TARGET_CONDITION_ID=0xbb57ccf5853a85487bc3d83d04d669310d28c6c810758953b9d9b91d1aee89d2

# 目标问题描述（仅用于日志显示）
TARGET_QUESTION=Will bitcoin hit $1m before GTA VI?
